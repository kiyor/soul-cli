<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.kiyor.weiran-server</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/kiyor/.local/bin/weiran</string>
        <string>server</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/kiyor/.openclaw/data/weiran-server.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/kiyor/.openclaw/data/weiran-server.stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/kiyor/.openclaw/workspace</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/kiyor</string>
        <key>PATH</key>
        <string>/Users/kiyor/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>ThrottleInterval</key>
    <integer>5</integer>
</dict>
</plist>
